# 1. Start by ignoring everything
*

# 2. Global Whitelist
!*.py
!*.sh
!*.md
!*.txt
!*.json
!*.yaml
!*.yml
!*.toml
!LICENSE
!.gitignore
!requirements.txt
!.github/
!.github/**
!icon.ico

# 3. IGNORE DOWNLOADS (Look like music playlist folders)
/*[A-Za-z0-9]*/

# 4. OVERRIDE: ALWAYS allow the source code package structure
!spotdlextended/
!spotdlextended/**
!bin/
!bin/sockseek.exe

# 5. FINAL SAFETY IGNORES (These must be at the bottom to stay ignored)
.venv/
__pycache__/
*.pyc
.pyc
settings.json
local_settings.json
.DS_Store
Thumbs.db
